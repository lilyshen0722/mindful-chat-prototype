# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# OpenRouter — get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Admin dashboard (HTTP Basic) — change for any non-localhost use
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-locally

# Host port the API is published on (the container is always 8000 internally).
# Override if 8000 is taken on your machine.
HOST_PORT=8000

# Storage
DATABASE_PATH=/data/app.db
LOG_LEVEL=INFO

# Second-tier emotion classifier. Set ENABLE_ML_CLASSIFIER=false to run the
# guardrail with the regex tier alone (smaller image, faster cold start).
ENABLE_ML_CLASSIFIER=true
ML_CLASSIFIER_MODEL=SamLowe/roberta-base-go_emotions
ML_CLASSIFIER_THRESHOLD=0.4
ML_CLASSIFIER_MIN_WORDS=4

# Third-tier LLM-judge. Consulted only when regex + ML both return NONE.
# Adds ~1-2s latency per chat turn. Set false to disable.
ENABLE_LLM_JUDGE=true
# Empty = use the same model as the chat. Override to point at a smaller /
# faster / different-vendor model for cost or privacy reasons.
LLM_JUDGE_MODEL=
LLM_JUDGE_MIN_WORDS=6
LLM_JUDGE_TIMEOUT=10.0
